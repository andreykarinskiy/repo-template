htmlcov/
*.cover

# Java/Kotlin
*.class
target/
*.jar
*.war
*.ear
.gradle/
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

# .NET
bin/
obj/
*.dll
*.exe
*.pdb
.vs/
*.user
*.suo

# Go
*.exe
*.exe~
*.test
*.out
vendor/

# Rust
target/
Cargo.lock
**/*.rs.bk

# === Temporary and Cache ===

# General
*.tmp
*.temp
*.log
*.bak
*.swp
*.swo
*~
.cache/
temp/
tmp/

