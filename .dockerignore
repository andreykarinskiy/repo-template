# .dockerignore for multi-language template
# Files and directories that should not be copied to Docker image

# === Version Control ===
.git/
.gitignore
.gitattributes
.gitmodules

# === CI/CD ===
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
.azure-pipelines.yml
azure-pipelines.yml
Jenkinsfile
.buildkite/

# === IDEs and Editors ===
.idea/
.vscode/
.vs/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.editorconfig

# === Documentation ===
docs/
*.md
!README.md
LICENSE
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
CHANGELOG.md

# === Testing ===
tests/
test/
__tests__/
*.test.*
*.spec.*
.pytest_cache/
.coverage
coverage/
htmlcov/
.tox/
.nox/
junit.xml
test-results/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.dmypy.json
.pytype/
poetry.lock
Pipfile.lock

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
package-lock.json
yarn.lock
.pnpm-debug.log*

# === Java/Kotlin ===
target/
*.class
.gradle/
gradle/
gradlew
gradlew.bat
.gradletasknamecache
*.jar
*.war
*.ear
!**/src/main/**/target/
!**/src/test/**/target/

# === .NET ===
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
packages/
.vs/

# === Go ===
vendor/
*.test
*.out

# === Rust ===
target/
Cargo.lock
**/*.rs.bk

# === Build Artifacts ===
dist/
build/
out/
*.min.js
*.min.css

# === OS Files ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# === Logs and Temporary Files ===
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.swp
*.swo

# === Environment and Secrets ===
.env
.env.*
!.env.example
.envrc
secrets/
*.pem
*.key
*.cert
credentials.json

# === Database ===
*.db
*.sqlite
*.sqlite3

# === Copier ===
.copier-answers.yml
copier.yml

# === Project Specific ===
.snapshots/
.cache/
Makefile
scripts/
*.backup

# === Docker ===
Dockerfile*
!Dockerfile
.dockerignore
docker-compose*.yml

# === Miscellaneous ===
*.orig
*.rej
*.bkp
