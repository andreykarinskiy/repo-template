# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# JavaScript/TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# Python files
[*.py]
indent_size = 4
max_line_length = 120

# Java/Kotlin
[*.{java,kt}]
indent_size = 4

# C#
[*.cs]
indent_size = 4

# Go
[*.go]
indent_style = tab
indent_size = 4

# Shell scripts
[*.{sh,bash}]
indent_size = 2
end_of_line = lf

# Windows scripts
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Makefiles
[{Makefile,makefile,*.mk}]
indent_style = tab

# Configuration files
[*.{toml,ini,cfg,conf}]
indent_size = 2

# XML files
[*.xml]
indent_size = 2

# Web files
[*.{html,css,scss,sass,less}]
indent_size = 2

# SQL files
[*.sql]
indent_size = 2

# Jinja templates
[*.{jinja,j2}]
indent_size = 2

